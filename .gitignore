# Dependencies
node_modules/

# Yarn Berry local state and cache. Keep intentional repo-managed Yarn files
# such as .yarnrc.yml, yarn.lock, releases, plugins, patches, SDKs, and versions.
.yarn/*
!.yarn/patches/
!.yarn/plugins/
!.yarn/releases/
!.yarn/sdks/
!.yarn/versions/

# Plug'n'Play artifacts if nodeLinker changes later.
.pnp.*

# Build output
dist/
coverage/
*.tsbuildinfo

# Vite/VitePress output
.vite/
docs/.vitepress/dist/
docs/.vitepress/cache/

# Package artifacts
*.tgz
package.tgz

# Generated local schemas
/openapi.json
/openapi.yaml

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Local environment files
.env
.env.local
.env.*.local

# OS/editor noise
.DS_Store
Thumbs.db
.serena/
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json

.working/

.tmp-*
